# SecureVote Backend Environment Variables
# Copy this file to .env and fill in your values

# Flask secret key for JWT signing (REQUIRED in production)
SECRET_KEY=change-me-to-a-random-secret

# MongoDB connection URI
MONGO_URI=mongodb://localhost:27017/securevote

# RSA private key passphrase (optional, recommended in production)
RSA_KEY_PASSPHRASE=

# Flask environment (development / production)
FLASK_ENV=development

# Frontend URL for CORS (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:3000

# Admin credentials for create_admin.py script
ADMIN_PASSWORD=

# WebAuthn / Passkey configuration
# RP_ID must match the domain the frontend is served from (no port, no protocol)
# ORIGIN must be the exact origin (protocol + host + port) of the frontend
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=SecureVote
WEBAUTHN_ORIGIN=http://localhost:3000
